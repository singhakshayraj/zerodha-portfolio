# ─────────────────────────────────────────────────────────────────
# Portfolio Intelligence — Environment Variables
# Copy this to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────────

# Runtime mode
# "local"  → use Claude Code CLI + Kite MCP (default, no API keys needed)
# "server" → use direct API keys (GitHub Actions, Vercel, any server)
RUNTIME_MODE=local

# ── Kite (required in server mode) ───────────────────────────────
# Extract enctoken from browser DevTools after logging into kite.zerodha.com
# Cookies → kite.zerodha.com → enctoken
# Refreshes roughly weekly — update here and in GitHub Secrets when it expires.
KITE_ENCTOKEN=

# ── LLM Provider ─────────────────────────────────────────────────
# Options: groq | claude | openai
LLM_PROVIDER=groq

# Groq (fast, free tier available — https://console.groq.com)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Server ───────────────────────────────────────────────────────
PORT=7432
